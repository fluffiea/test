{
  "name": "@momoya/shared",
  "version": "0.0.1",
  "private": true,
  "description": "前后端共享的领域类型 / 常量 / 错误码。仅纯 TS，不含任何运行时依赖。",
  "license": "UNLICENSED",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm build:cjs && pnpm build:esm && pnpm build:esm:fixup",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:esm:fixup": "node scripts/fixup-esm.js",
    "dev": "tsc -p tsconfig.cjs.json --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
