# docker-compose.prod.yml 使用的环境变量示例。
# 首次部署前复制为 .env.docker 并改为真实值，然后执行：
#   docker compose --env-file .env.docker -f docker-compose.prod.yml up -d --build

# ---------- MongoDB 初始化账号 ----------
# 仅在容器首次创建（/data/db 为空）时被使用。
# 后续想改密码需要清空 mongo-prod-data 卷或手动 db.updateUser。
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=please-change-me-root-password

# 应用连接 MongoDB 使用的独立账号（仅 momoya 数据库 readWrite 权限）。
MOMOYA_APP_USERNAME=momoya_app
MOMOYA_APP_PASSWORD=please-change-me-app-password

# ---------- Redis（Socket.IO adapter，compose 内由 server 使用）----------
# 生产 compose 已在 server 服务写死 redis://redis:6379，一般无需再改。

# ---------- NestJS server ----------
# 必须手动设置至少 32 字节的强随机字符串，access / refresh 两把密钥不要相同。
JWT_ACCESS_SECRET=please-change-me-to-a-random-string-of-at-least-32-chars
JWT_ACCESS_TTL=2h
JWT_REFRESH_SECRET=please-change-me-to-another-random-string-of-at-least-32-chars
JWT_REFRESH_TTL=14d

# 静态资源的公网访问前缀（图片 URL 中会用到）。
STATIC_BASE_URL=http://localhost:3000/static

# 单张上传图片大小上限，单位字节（默认 5MB）。
UPLOAD_MAX_SIZE_BYTES=5242880

# 对外暴露的端口；内部始终监听 3000。
SERVER_PORT=3000

# 镜像 tag，便于多版本共存；默认 latest。
MOMOYA_SERVER_TAG=latest

# Swagger / OpenAPI。生产默认关闭；如需打开用于内网联调，把下一行改为 true。
# SWAGGER_ENABLED=false
