NODE_ENV=development
PORT=3000

# 本机直跑：使用本地 MongoDB 或 docker-compose.yml 中暴露到 27017 的开发 mongo
MONGODB_URI=mongodb://127.0.0.1:27017/momoya
# 在 docker-compose.prod.yml 内部，server 容器会使用的格式（仅示例，不要在本地 .env 中启用）：
# MONGODB_URI=mongodb://momoya_app:password@mongo:27017/momoya?authSource=momoya

# 与 `pnpm docker:dev:up` 中的 redis 服务对应（本机映射 6379）
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=please-change-me-to-a-random-string-of-at-least-32-chars
JWT_ACCESS_TTL=2h
# access 与 refresh 必须分开，避免 refresh token 被当作 access 直接打业务接口
JWT_REFRESH_SECRET=please-change-me-to-another-random-string-of-at-least-32-chars
JWT_REFRESH_TTL=14d
UPLOAD_DIR=./uploads
STATIC_BASE_URL=http://localhost:3000/static
# 单张图片大小上限，单位字节（默认 5MB）
UPLOAD_MAX_SIZE_BYTES=5242880

# Swagger / OpenAPI。默认：非 production 开启，production 关闭。显式设置可覆盖。
# 打开后访问 http://localhost:3000/api/docs（UI）与 /api/docs-json（给 Apifox 拉）。
# SWAGGER_ENABLED=true
# SWAGGER_PATH=api/docs
